{
  "manifest_version": 3,
  "name": "De-Clickbait",
  "version": "0.1.0",
  "description": "Rewrites clickbait YouTube titles with accurate AI-generated ones using the video transcript.",

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "host_permissions": [
    "*://*.youtube.com/*",
    "https://*.execute-api.us-west-1.amazonaws.com/*"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "declickbait@extension",
      "strict_min_version": "109.0"
    }
  }
}
